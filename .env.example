PORT=8080
DB_DSN=postgres://user:password@localhost:5432/nombasub?sslmode=disable
# Generate strong, unique secrets (>=32 chars). The app refuses to boot with a
# placeholder value. e.g. `openssl rand -base64 48`
JWT_SECRET=
JWT_REFRESH_SECRET=
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
API_KEY_HEADER=X-Api-Key
# Base64-encoded 32-byte key for AES-256-GCM. e.g. `openssl rand -base64 32`
ENCRYPTION_KEY=
# Set to "true" only when diagnosing Nomba integration issues; enables verbose
# request/response logging that includes PII. Keep unset in production.
NOMBA_DEBUG_LOGGING=
CLIENT_URL=
NOMBA_ACCOUNT_ID=
NOMBA_SUBACCOUNT_ID=
NOMBA_CLIENT_ID=
NOMBA_CLIENT_SECRET=
NOMBA_WEBHOOK_SECRET=
MAILER_USER=
MAILER_PASSWORD=
